# LLM
GROQ_API_KEY=your_groq_api_key_here

# Reranking
COHERE_API_KEY=your_cohere_api_key_here

# Vector store (local persistent ChromaDB, no external service needed)
CHROMA_PERSIST_DIR=./data/chroma_store
CHROMA_COLLECTION_NAME=policy_docs

# Embedding model (runs locally via sentence-transformers)
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# App
APP_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:5600,http://127.0.0.1:5600

# Database (SQLite — single file, no separate server needed)
DATABASE_URL=sqlite:///./data/wrennon.db

# Agent auth
# JWT_SECRET_KEY: any long random string. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

AGENT_USERNAME=mubin
# AGENT_PASSWORD_HASH: run scripts/generate_agent_password.py and paste
# the output here. Never put the plain password in this file.
AGENT_PASSWORD_HASH=

